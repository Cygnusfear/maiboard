{
  "name": "maiboard-workspace",
  "version": "0.3.1",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev:board": "bun run --filter @maiboard/board dev",
    "dev:vscode": "bun run --filter maiboard dev",
    "build": "bun run --workspaces build",
    "build:board": "bun run --filter @maiboard/board build",
    "build:server": "bun run --filter @maiboard/server build",
    "build:cli": "bun run --filter @maiboard/cli build",
    "build:vscode": "bun run --filter maiboard build",
    "package:vscode": "bun run --filter maiboard package",
    "typecheck": "bun run --workspaces typecheck",
    "lint": "bunx oxlint --no-error-on-unmatched-pattern src packages/*/src && bunx oxfmt --check package.json tsconfig.base.json README.md packages/*/package.json packages/*/src",
    "fmt": "bunx oxlint --no-error-on-unmatched-pattern src packages/*/src --fix && bunx oxfmt package.json tsconfig.base.json README.md packages/*/package.json packages/*/src",
    "setup-hooks": "git config core.hooksPath .githooks"
  },
  "devDependencies": {
    "bun-types": "^1.3.9",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "typescript": "^5.9.3"
  }
}
